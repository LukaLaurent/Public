<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Dietagro Infrastructure</title>

<style>
body {
    font-family: Arial, sans-serif;
    background: #0f172a;
    color: white;
    margin: 0;
}

header {
    background: #1e293b;
    padding: 20px;
    text-align: center;
}

section {
    padding: 20px;
}

h2 {
    border-bottom: 2px solid #334155;
    padding-bottom: 5px;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 15px;
    margin-top: 15px;
}

.card {
    background: #1e293b;
    padding: 15px;
    border-radius: 10px;
    cursor: pointer;
    transition: 0.2s;
}

.card:hover {
    background: #334155;
}

.modal {
    display: none;
    position: fixed;
    top:0; left:0;
    width:100%; height:100%;
    background: rgba(0,0,0,0.8);
}

.modal-content {
    background:#1e293b;
    margin:10% auto;
    padding:20px;
    width:400px;
    border-radius:10px;
}
</style>
</head>

<body>

<header>
    <h1>Dietagro Infrastructure</h1>
    <p>Domain: dietagro.com</p>
    <p>Students: Luka LAURENT, Leopold LECUYER, Nathan MOULIN</p>
</header>

<section>
    <h2>🔥 MAIN</h2>
    <div class="grid" id="main"></div>
</section>

<section>
    <h2>🖥️ VLAN SRV</h2>
    <div class="grid" id="srv"></div>
</section>

<section>
    <h2>🌐 VLAN DMZ</h2>
    <div class="grid" id="dmz"></div>
</section>

<div class="modal" id="modal">
    <div class="modal-content" id="modalContent"></div>
</div>

<script>
const data = {
    main: [
        {name:"FR-DTG-FW01", ip:"192.168.1.2", desc:"Firewall 1"},
        {name:"FR-DTG-FW02", ip:"192.168.1.3", desc:"Firewall 2"}
    ],
    srv: [
        {name:"FR-DTG-AD01", ip:"192.168.2.10", desc:"Microsoft AD 1"},
        {name:"FR-DTG-AD02", ip:"192.168.2.20", desc:"Microsoft AD 2"},
        {name:"FR-DTG-PF01", ip:"192.168.2.30", desc:"PacketFence (NAC & Radius)"},
        {name:"FR-DTG-PF02", ip:"192.168.2.35", desc:"PacketFence (NAC & Radius)"},
        {name:"FR-DTG-ZABBIX01", ip:"192.168.2.40", desc:"Zabbix Monitoring"},
        {name:"FR-DTG-SIEM01", ip:"192.168.2.50", desc:"SIEM (Wazuh & LLaMA)"}
    ],
    dmz: [
        {name:"FR-DTG-WEB01", ip:"192.168.3.10", desc:"Web Server (infra.dietagro.com)"}
    ]
};

function render(section, elementId) {
    const container = document.getElementById(elementId);
    section.forEach(machine => {
        const div = document.createElement("div");
        div.className = "card";
        div.innerHTML = `<b>${machine.name}</b><br>${machine.ip}`;
        
        div.onclick = () => {
            modal.style.display = "block";
            modalContent.innerHTML = `
                <h2>${machine.name}</h2>
                <p><b>IP:</b> ${machine.ip}</p>
                <p><b>Description:</b> ${machine.desc}</p>
            `;
        };

        container.appendChild(div);
    });
}

render(data.main, "main");
render(data.srv, "srv");
render(data.dmz, "dmz");

const modal = document.getElementById("modal");
modal.onclick = () => modal.style.display = "none";
</script>

</body>
</html>
