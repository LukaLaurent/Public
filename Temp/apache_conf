<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Infrastructure Dashboard</title>
<style>
body {
    font-family: Arial, sans-serif;
    background: #0f172a;
    color: white;
    margin: 0;
}

header {
    padding: 20px;
    text-align: center;
    background: #1e293b;
    font-size: 24px;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    padding: 20px;
}

.card {
    background: #1e293b;
    padding: 20px;
    border-radius: 12px;
    cursor: pointer;
    transition: 0.3s;
}

.card:hover {
    background: #334155;
}

.modal {
    display: none;
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.8);
}

.modal-content {
    background: #1e293b;
    margin: 10% auto;
    padding: 20px;
    width: 400px;
    border-radius: 12px;
}
</style>
</head>

<body>

<header>Infrastructure Dashboard</header>

<div class="grid" id="grid"></div>

<div class="modal" id="modal">
    <div class="modal-content" id="modalContent"></div>
</div>

<script>
const machines = [
    {
        name: "Web Server",
        ip: "192.168.1.10",
        description: "Apache hosting internal apps",
        password: "admin123"
    },
    {
        name: "Database",
        ip: "192.168.1.20",
        description: "PostgreSQL server",
        password: "dbpass"
    },
    {
        name: "Backup Server",
        ip: "192.168.1.30",
        description: "Daily backups",
        password: "backup!"
    }
];

const grid = document.getElementById("grid");
const modal = document.getElementById("modal");
const modalContent = document.getElementById("modalContent");

machines.forEach(machine => {
    const div = document.createElement("div");
    div.className = "card";
    div.innerHTML = `<h3>${machine.name}</h3><p>${machine.ip}</p>`;
    
    div.onclick = () => {
        modal.style.display = "block";
        modalContent.innerHTML = `
            <h2>${machine.name}</h2>
            <p><b>IP:</b> ${machine.ip}</p>
            <p><b>Description:</b> ${machine.description}</p>
            <p><b>Password:</b> ${machine.password}</p>
        `;
    };

    grid.appendChild(div);
});

modal.onclick = () => modal.style.display = "none";
</script>

</body>
</html>
